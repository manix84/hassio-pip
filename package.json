{
  "name": "ha-tv-pip",
  "version": "0.46.0",
  "private": true,
  "description": "Monorepo for the HA TV PiP Android TV receiver and future Home Assistant integration.",
  "license": "MIT",
  "scripts": {
    "android:assemble": "npm --prefix android-tv-app run assemble",
    "android:assemble:debug": "npm --prefix android-tv-app run assemble:debug",
    "android:assemble:release": "npm --prefix android-tv-app run assemble:release",
    "android:build:dry-run": "npm run android:assemble:debug",
    "android:bundle:release": "npm --prefix android-tv-app run bundle:release",
    "android:clean": "npm --prefix android-tv-app run clean",
    "android:lint": "npm --prefix android-tv-app run lint",
    "android:typecheck": "npm --prefix android-tv-app run typecheck",
    "check": "npm run version:check && npm run lint && npm run typecheck && npm run test",
    "ha:check": "npm --prefix ha-integration run check",
    "ha:build:dry-run": "npm run package:integration",
    "ha:install": "node scripts/install-ha-python-tools.mjs",
    "ha:lint": "npm --prefix ha-integration run lint",
    "ha:test": "npm --prefix ha-integration run test",
    "ha:typecheck": "npm --prefix ha-integration run typecheck",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "install:all": "node scripts/install-all.mjs",
    "lint": "npm run android:lint && npm run ha:lint && npm run website:lint",
    "package:integration": "node scripts/package-integration.mjs",
    "prepare": "npm run hooks:install",
    "test": "npm run android:test && npm run ha:test && npm run website:test",
    "typecheck": "npm run android:typecheck && npm run ha:typecheck && npm run website:typecheck",
    "version:check": "node scripts/check-version.mjs",
    "version:major": "node scripts/bump-version.mjs major",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:precommit": "node scripts/precommit-version-bump.mjs",
    "android:test": "npm --prefix android-tv-app run test",
    "website:build": "npm --prefix website run build",
    "website:build:dry-run": "npm run website:build",
    "website:check": "npm --prefix website run check",
    "website:dev": "npm --prefix website run dev",
    "website:lint": "npm --prefix website run lint",
    "website:preview": "npm --prefix website run preview",
    "website:test": "npm --prefix website run test",
    "website:typecheck": "npm --prefix website run typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
